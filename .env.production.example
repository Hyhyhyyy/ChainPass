# =====================================================
# ChainPass 生产环境配置模板
# 复制此文件为 .env.production 并填写实际值
# =====================================================

# ==================== 数据库配置 ====================
# MySQL 连接地址
DB_URL=jdbc:mysql://localhost:3306/chainpass?useUnicode=true&characterEncoding=utf-8&useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai

# 数据库用户名（建议使用专用账户而非root）
DB_USERNAME=chainpass

# 数据库密码（请使用强密码，至少16位）
DB_PASSWORD=your_secure_db_password_here

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis 密码（生产环境必须设置）
REDIS_PASSWORD=your_secure_redis_password_here

# ==================== JWT 配置 ====================
# JWT 签名密钥（至少64字符的Base64字符串）
# 生成命令: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long_please_change_this

# Access Token 有效期（毫秒）
# 15分钟 = 900000
JWT_ACCESS_TOKEN_TTL=900000

# Refresh Token 有效期（毫秒）
# 7天 = 604800000
JWT_REFRESH_TOKEN_TTL=604800000

# ==================== OAuth 配置 ====================
# Gitee OAuth 应用配置
# 注册地址: https://gitee.com/oauth/applications
GITEE_CLIENT_ID=your_gitee_client_id
GITEE_CLIENT_SECRET=your_gitee_client_secret
GITEE_REDIRECT_URI=https://your-domain.com/oauth/gitee/callback

# OAuth State 加密密钥
OAUTH_STATE_SECRET=your_oauth_state_secret_here

# ==================== 服务器配置 ====================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# HTTPS 配置
SERVER_SSL_ENABLED=true
SSL_KEY_STORE=classpath:keystore.p12
SSL_KEY_STORE_PASSWORD=your_keystore_password
SSL_KEY_STORE_TYPE=PKCS12

# ==================== 日志配置 ====================
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO

# ==================== 跨域配置 ====================
# 允许的前端域名（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ==================== 安全配置 ====================
# 是否启用请求限流
RATE_LIMIT_ENABLED=true

# 每分钟最大请求数
RATE_LIMIT_REQUESTS_PER_MINUTE=100